# Laravel App - Environment Variables
# Copy ke .env dan sesuaikan

APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000

# Database
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=your_secure_password_here
DB_ROOT_PASSWORD=your_root_password_here

# Pantra labels
TEAM_NAME=backend
PROJECT_NAME=myapp

# Logging (gunakan stderr supaya Docker bisa capture)
LOG_CHANNEL=stderr
LOG_LEVEL=info
