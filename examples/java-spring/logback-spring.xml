<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback Spring Config - JSON Structured Logging untuk Pantra
  Taruh di src/main/resources/logback-spring.xml

  Dependencies (pom.xml):
    <dependency>
      <groupId>net.logstash.logback</groupId>
      <artifactId>logstash-logback-encoder</artifactId>
      <version>7.4</version>
    </dependency>
-->
<configuration>

  <!-- Property dari Spring -->
  <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="spring-api"/>
  <springProperty scope="context" name="appEnv" source="spring.profiles.active" defaultValue="development"/>

  <!-- ===== Production Profile: JSON ke stdout ===== -->
  <springProfile name="production,staging">
    <appender name="JSON_STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <!-- Custom field names -->
        <fieldNames>
          <timestamp>timestamp</timestamp>
          <version>[ignore]</version>
          <levelValue>[ignore]</levelValue>
        </fieldNames>

        <!-- Static fields -->
        <customFields>{"service":"${appName}","env":"${appEnv}"}</customFields>

        <!-- Timestamp format -->
        <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
        <timeZone>UTC</timeZone>

        <!-- Include MDC (request context) -->
        <includeMdcKeyName>requestId</includeMdcKeyName>
        <includeMdcKeyName>userId</includeMdcKeyName>
        <includeMdcKeyName>traceId</includeMdcKeyName>

        <!-- Stack trace -->
        <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
          <maxDepthPerThrowable>30</maxDepthPerThrowable>
          <maxLength>2048</maxLength>
          <shortenedClassNameLength>20</shortenedClassNameLength>
          <rootCauseFirst>true</rootCauseFirst>
        </throwableConverter>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="JSON_STDOUT"/>
    </root>

    <!-- Reduce noisy loggers -->
    <logger name="org.springframework.web" level="WARN"/>
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.apache.kafka" level="WARN"/>
  </springProfile>

  <!-- ===== Development Profile: Pretty print ===== -->
  <springProfile name="development,default">
    <appender name="PRETTY_STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) - %msg%n%throwable</pattern>
      </encoder>
    </appender>

    <root level="DEBUG">
      <appender-ref ref="PRETTY_STDOUT"/>
    </root>

    <!-- Show SQL in dev -->
    <logger name="org.hibernate.SQL" level="DEBUG"/>
  </springProfile>

</configuration>
