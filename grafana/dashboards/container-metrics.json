{
  "annotations": {"list": []},
  "editable": true,
  "id": null,
  "panels": [
    {
      "type": "stat",
      "title": "Total Containers",
      "id": 1,
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "count(count by (name) (container_last_seen{name!=\"\"}))", "refId": "A"}],
      "options": {"colorMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "stat",
      "title": "Running",
      "id": 2,
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "count(count by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[1m]) > 0))", "refId": "A"}],
      "fieldConfig": {"defaults": {"color": {"mode": "fixed", "fixedColor": "green"}}},
      "options": {"colorMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "stat",
      "title": "Total CPU (containers)",
      "id": 3,
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(container_cpu_usage_seconds_total{name!=\"\"}[2m])) * 100", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent"}},
      "options": {"colorMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "stat",
      "title": "Total RAM (containers)",
      "id": 4,
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(container_memory_working_set_bytes{name!=\"\"})", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "options": {"colorMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "timeseries",
      "title": "CPU per Container",
      "id": 5,
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[2m])) * 100", "legendFormat": "{{name}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent"}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "type": "timeseries",
      "title": "Memory per Container",
      "id": 6,
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (name) (container_memory_working_set_bytes{name!=\"\"})", "legendFormat": "{{name}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "type": "timeseries",
      "title": "Network RX per Container",
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (name) (rate(container_network_receive_bytes_total{name!=\"\"}[2m]))", "legendFormat": "{{name}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "timeseries",
      "title": "Network TX per Container",
      "id": 8,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (name) (rate(container_network_transmit_bytes_total{name!=\"\"}[2m]))", "legendFormat": "{{name}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "table",
      "title": "Container Top Resource Usage",
      "id": 9,
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 21},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "topk(20, sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[2m])) * 100)", "legendFormat": "{{name}}", "refId": "A", "format": "table", "instant": true},
        {"expr": "topk(20, sum by (name) (container_memory_working_set_bytes{name!=\"\"}))", "legendFormat": "{{name}}", "refId": "B", "format": "table", "instant": true}
      ],
      "transformations": [
        {"id": "merge", "options": {}},
        {"id": "organize", "options": {"renameByName": {"Value #A": "CPU %", "Value #B": "RAM bytes"}}}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["containers", "docker"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "title": "Container Metrics",
  "uid": "container-metrics",
  "version": 1
}
