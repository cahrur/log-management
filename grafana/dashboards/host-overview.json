{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "CPU Usage",
      "id": 1,
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 85}
            ]
          }
        }
      },
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "stat",
      "title": "RAM Usage",
      "id": 2,
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 75},
              {"color": "red", "value": 90}
            ]
          }
        }
      },
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "stat",
      "title": "Disk Usage (/)",
      "id": 3,
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"})) * 100", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 85}
            ]
          }
        }
      },
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "stat",
      "title": "Uptime",
      "id": 4,
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "node_time_seconds - node_boot_time_seconds", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"colorMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "timeseries",
      "title": "CPU Usage (per mode)",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "avg by (mode) (rate(node_cpu_seconds_total{mode!=\"idle\"}[2m])) * 100", "legendFormat": "{{mode}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"fillOpacity": 20, "stacking": {"mode": "normal"}}}}
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used", "refId": "A"},
        {"expr": "node_memory_Buffers_bytes + node_memory_Cached_bytes", "legendFormat": "Cache/Buffer", "refId": "B"},
        {"expr": "node_memory_MemAvailable_bytes", "legendFormat": "Available", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"fillOpacity": 20}}}
    },
    {
      "type": "timeseries",
      "title": "Network Traffic",
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[2m]))", "legendFormat": "RX", "refId": "A"},
        {"expr": "sum(rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[2m]))", "legendFormat": "TX", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "timeseries",
      "title": "Disk I/O",
      "id": 8,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(node_disk_read_bytes_total[2m]))", "legendFormat": "Read", "refId": "A"},
        {"expr": "sum(rate(node_disk_written_bytes_total[2m]))", "legendFormat": "Write", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "timeseries",
      "title": "Load Average",
      "id": 9,
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "node_load1", "legendFormat": "1m", "refId": "A"},
        {"expr": "node_load5", "legendFormat": "5m", "refId": "B"},
        {"expr": "node_load15", "legendFormat": "15m", "refId": "C"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk Space (filesystem)",
      "id": 10,
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "(1 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|fuse.lxcfs\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|fuse.lxcfs\"})) * 100", "legendFormat": "{{mountpoint}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["host", "infrastructure"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "Host Overview",
  "uid": "host-overview",
  "version": 1,
  "weekStart": ""
}
