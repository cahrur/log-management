# ==============================================================
# LOG MANAGEMENT STACK - Environment Configuration
# Copy file ini ke .env dan sesuaikan
# ==============================================================

# ----- Grafana -----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_strong_password_here
GRAFANA_PORT=3000
# Grafana punya login, default boleh 0.0.0.0 (akses dari browser)
GRAFANA_BIND=0.0.0.0

# Optional: Domain buat Grafana (kalau pake reverse proxy / domain)
# GRAFANA_ROOT_URL=https://grafana.example.com

# ----- Prometheus -----
PROMETHEUS_PORT=9090
# WAJIB localhost - Prometheus gak punya auth, jangan expose public
# Akses via: SSH tunnel `ssh -L 9090:127.0.0.1:9090 user@vps` atau reverse proxy + auth
PROMETHEUS_BIND=127.0.0.1
# Retention metrics (default 30d). Format: 15d, 30d, 90d
PROMETHEUS_RETENTION=30d

# ----- Loki -----
# Retention log (default 14d). Format pakai jam: 336h = 14 hari
LOKI_RETENTION_HOURS=336h

# ----- cAdvisor -----
CADVISOR_PORT=8080
# WAJIB localhost - cAdvisor gak punya auth
CADVISOR_BIND=127.0.0.1

# ----- Alertmanager -----
ALERTMANAGER_PORT=9093
# WAJIB localhost - Alertmanager gak punya auth
ALERTMANAGER_BIND=127.0.0.1

# ----- Telegram Alerting (OPSIONAL) -----
# Bikin bot di @BotFather, dapetin token
# Chat ID: chat sama @userinfobot atau @RawDataBot buat dapet ID
# Kosongin kalau gak mau alert ke Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- Host Settings -----
# Hostname VPS (buat label di metric/alert)
VPS_HOSTNAME=dealtech-vps
